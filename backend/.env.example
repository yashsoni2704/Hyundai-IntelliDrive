# Copy to .env and adjust as needed

# Path to the FAQ Excel file
EXCEL_PATH=../data/hyundai_faq.xlsx

# Where ChromaDB persists data
CHROMA_PERSIST_DIR=./chroma_db

# ChromaDB collection name
COLLECTION_NAME=hyundai_faq

# Sentence-transformers model (local, no API key)
EMBEDDING_MODEL=BAAI/bge-m3

# Render free tier (512 MB): set true to skip PyTorch and use keyword FAQ search
# LIGHTWEIGHT_MODE=true

# Minimum similarity to return an answer (0–1)
# Lower = more permissive, Higher = more strict
SIMILARITY_THRESHOLD=0.55

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://hyundai-intelli-drive-frontend.vercel.app

# SQLite database (default: backend/app.db)
# DATABASE_URL=sqlite:///./app.db

# JWT secret — change in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRE_MINUTES=1440

# Brevo SMTP for OTP emails — https://app.brevo.com/settings/keys/smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-login@smtp-brevo.com
SMTP_PASSWORD=your-brevo-smtp-key
# Must match a verified sender in Brevo (Senders & IP → Senders)
SMTP_FROM_EMAIL=your-email@gmail.com

# When true and email is not configured, OTP is logged in server console only (never shown in UI)
DEBUG_MODE=false
